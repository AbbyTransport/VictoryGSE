
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return signedIn() && userProfile().role == "admin";
    }

    function isClient() {
      return signedIn() && userProfile().role == "client";
    }

    function userCompanyId() {
      return userProfile().companyId;
    }

    function isOwnClientLoad() {
      return isClient() && resource.data.companyId == userCompanyId();
    }

    function clientCreateIsValid() {
      return isClient()
        && request.resource.data.companyId == userCompanyId()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.status == "Submitted";
    }

    function clientUpdateIsValid() {
      return isOwnClientLoad()
        && request.resource.data.companyId == resource.data.companyId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "requesterName",
          "customerReference",
          "pickupDate",
          "pickupTime",
          "pickupLocation",
          "deliveryDate",
          "deliveryTime",
          "deliveryLocation",
          "commodity",
          "weight",
          "customerRate",
          "approvedInitials",
          "pickupContactName",
          "pickupContactPhone",
          "deliveryContactName",
          "deliveryContactPhone",
          "notes",
          "equipment",
          "chatMessages",
          "chatLastMessageAt",
          "chatLastSender",
          "chatUnreadForAdmin",
          "chatUnreadForClient",
          "chatReadByClientAt",
          "updatedAt"
        ]);
    }

    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow create, update, delete: if false;
    }

    match /loads/{loadId} {
      allow read: if isAdmin() || isOwnClientLoad();
      allow create: if isAdmin() || clientCreateIsValid();
      allow update: if isAdmin() || clientUpdateIsValid();
      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
